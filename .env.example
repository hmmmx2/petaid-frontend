# Public — exposed to the browser. Base URL of the FastAPI backend.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Auth.js (NextAuth v5) — server-only. Required.
# Generate one with:  node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET=replace-with-a-long-random-string
# Needed on platforms that don't set the host header (and locally). On Vercel
# this is inferred, but leaving it true is harmless.
AUTH_TRUST_HOST=true
